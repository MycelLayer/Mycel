{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycel.local/schemas/topology.schema.json",
  "title": "Mycel Peer Simulator Topology",
  "description": "Language-neutral peer graph and bootstrap description for simulator runs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topology_id",
    "description",
    "fixture_set",
    "peers",
    "expected_outcomes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "topology_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "fixture_set": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "single-process",
        "multi-process"
      ]
    },
    "peers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "../peers/peer.schema.json"
      }
    },
    "expected_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
