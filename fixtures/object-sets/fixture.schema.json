{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycel.local/schemas/fixture.schema.json",
  "title": "Mycel Peer Simulator Fixture",
  "description": "Language-neutral metadata for one simulator fixture set.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "description",
    "seed_peer",
    "reader_peers",
    "expected_outcomes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "seed_peer": {
      "type": "string",
      "minLength": 1
    },
    "reader_peers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/documentRef"
      }
    },
    "expected_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "fault_peer": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "documentRef": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "doc_id"
      ],
      "properties": {
        "doc_id": {
          "type": "string",
          "minLength": 1
        },
        "head_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
