{
  "name": "mycel-docs-checks",
  "private": true,
  "scripts": {
    "handoffs:create": "python3 scripts/mailbox_handoff.py create",
    "handoffs:inactive-coding": "python3 scripts/inactive_coding_handoffs.py",
    "lint:docs": "npm run lint:pages",
    "lint:pages": "npm run lint:pages:html && npm run lint:pages:css",
    "lint:pages:html": "html-validate \"pages/**/*.html\"",
    "lint:pages:css": "stylelint \"pages/assets/**/*.css\""
  },
  "devDependencies": {
    "html-validate": "^10.11.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
